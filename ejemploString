int contarVocales(string s) {
	int cont = 0;
	for (int i = 0; i < s.length(); i++)
		if (s.at(i) == 'a' || s.at(i) == 'e' || s.at(i) == 'i' || s.at(i) == 'o' || s.at(i) == 'u')
			cont++;
	return cont;
}
int longitud(string s) {
	return s.length();

}
string extraerParte(string s, int pos) {
	return s.substr(pos, s.length() - pos);
}
void intercambioString(string s, string var) {
	// Intercambia string
	s.swap(var);
	cout << s<<endl;
	cout << var<<endl;
}
bool compararString(string  s, string s2) {

	if (s.compare(s2) == 0)
		return true;
	else
		return false;

}
int encontrarCaracter(string s, char c) {
	//Encuentra caracteres en string
	int pos = -1;
	for (int i = 0; i < s.length(); i++)
		if (s.at(i) == c)
			pos = i;
	return pos;
}
string invertirString(string s) {
	char aux;
	string var = s;
	int longitud = s.length();
	for (int i = 0; i < longitud / 2; i++)
	{
		aux = s[i];
		s[i] = s[longitud - 1 - i];
		s[longitud - 1 - i] = aux;
	}
	return s;
}
bool esCapicua(string s, string i) {
	if (i.compare(s) == 0)
		return true;
	return false;

}
string quitarVocales(string s) {
	//Quitar las vocales
	string var = "";
	for (int i = 0; i < s.length(); i++)
		if (s[i] != 'a' && s[i] != 'e' && s[i] != 'i' && s[i] != 'o' && s[i] != 'u')
		{
			var += s[i];
		}
	return var;
}
