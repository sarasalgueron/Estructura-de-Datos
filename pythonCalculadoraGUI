entry_comision = tk.Entry(ventana, font=("Arial", 12), justify="center", bg="#2b2b2b", fg="white", insertbackground="white", relief="flat", width=25)
entry_comision.pack(pady=5)

# Botones
frame_botones = tk.Frame(ventana, bg="#1e1e1e")
frame_botones.pack(pady=15)

tk.Button(
    frame_botones,
    text="De Bolivianos a Soles",
    font=("Arial", 10, "bold"),
    width=22,
    bg="#0078D7",
    fg="white",
    activebackground="#2893ff",
    activeforeground="white",
    relief="flat",
    bd=0,
    padx=10,
    pady=8,
    cursor="hand2",
    command=bolivianos_a_soles
).grid(row=0, column=0, padx=8)

tk.Button(
    frame_botones,
    text="De Soles a Bolivianos",
    font=("Arial", 10, "bold"),
    width=22,
    bg="#0078D7",
    fg="white",
