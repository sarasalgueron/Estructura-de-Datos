import tkinter as tk
from tkinter import messagebox


def bolivianos_a_soles():
    try:
        bolivianos = float(entry_monto.get())
        compra_usdt_bs = float(entry_compra_usdt_bs.get())
        venta_usdt_soles = float(entry_venta_usdt_soles.get())
        comision = float(entry_comision.get())

        usdt = bolivianos / compra_usdt_bs
        soles = usdt * venta_usdt_soles
        
        # Descuento de comisión
        descuento = soles * (comision / 100)
        soles_final = soles - descuento

        resultado.set(
            f"Con Bs {bolivianos:.2f} puedes recibir:\n"
            f"{usdt:.4f} USDT\n"
            f"S/ {soles:.2f}\n"
            f"Comisión ({comision:.1f}%): S/ {descuento:.2f}\n"
            f"Total Final: S/ {soles_final:.2f}"
        )

    except ValueError:
        messagebox.showerror("Error", "Ingrese solo números válidos.")


def soles_a_bolivianos():
    try:
        soles = float(entry_monto.get())
        compra_usdt_bs = float(entry_compra_usdt_bs.get())
        venta_usdt_soles = float(entry_venta_usdt_soles.get())
        comision = float(entry_comision.get())
        
         # Agregar comisión
        incremento = soles * (comision / 100)
        soles_con_comision = soles + incremento
        
        usdt = soles_con_comision / venta_usdt_soles
        bolivianos = usdt * compra_usdt_bs

        resultado.set(
            f"Para recibir S/ {soles:.2f} necesitas:\n"
            f"Comisión ({comision:.1f}%): S/ {incremento:.2f}\n"
            f"Total con comisión: S/ {soles_con_comision:.2f}\n"
            f"{usdt:.4f} USDT\n"
            f"Depositar Bs {bolivianos:.2f}"
        )

    except ValueError:
        messagebox.showerror("Error", "Ingrese solo números válidos.")


# Ventana principal
ventana = tk.Tk()
